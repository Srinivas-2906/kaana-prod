# ── Provider: "meta" (your setup) or "twilio" ──
WHATSAPP_PROVIDER=meta

# ── Meta WhatsApp Cloud API ──
WHATSAPP_ACCESS_TOKEN=paste_real_token_here_no_quotes
WHATSAPP_PHONE_NUMBER_ID=1092429373954144
WHATSAPP_BUSINESS_ACCOUNT_ID=1942212056411383
WHATSAPP_TEST_PHONE=919008747926
META_API_VERSION=v21.0
WHATSAPP_VERIFY_TOKEN=propbot_verify_token

# ── Twilio (only if WHATSAPP_PROVIDER=twilio) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

PORT=3002

# Public HTTPS URL from ngrok — required for phone to open listings & receive webhooks
PUBLIC_URL=https://YOUR-NGROK-URL.ngrok-free.dev
LISTINGS_BASE_URL=https://YOUR-NGROK-URL.ngrok-free.dev/listings

# Bot "typing..." pause before each reply (milliseconds)
TYPING_DELAY_MS=350

# ── Multi-tenant platform ──
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES=7d
DEFAULT_TENANT_ID=prestige-properties
PLATFORM_ADMIN_EMAIL=admin@kaana.ai
PLATFORM_ADMIN_PASSWORD=kaanaadmin

# Razorpay (optional — demo mode works without these)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Database (SQLite file, created automatically)
# DATABASE_PATH=./data/kaana.db

# Local dev: log WhatsApp replies to console instead of calling Meta API
WHATSAPP_DRY_RUN=true

# Concierge onboarding (default) vs self-serve signup
# Leave false for white-glove onboarding — first N customers manually activated
KAANA_SELF_SERVE=false
KAANA_CONCIERGE_SPOTS=10

# Business alerts — signups, questionnaires, payments
KAANA_NOTIFY_EMAIL=srinivas@kaana.in
# Optional: real email delivery via Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM=Kaana <onboarding@resend.dev>
